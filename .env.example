# ============================================================
# DATABASE (PostgreSQL) — pilih salah satu: Vercel Postgres / Supabase / Neon
# ============================================================
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# DIRECT_URL hanya perlu untuk Supabase/Neon (koneksi langsung untuk migrasi).
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ============================================================
# ADMIN — login panel /admin
# ============================================================
ADMIN_PASSWORD="ganti-dengan-sandi-kuat"
ADMIN_SECRET="string-acak-panjang-untuk-tanda-tangan-cookie"

# ============================================================
# MIDTRANS — ambil di dashboard.midtrans.com (mulai pakai Sandbox)
# ============================================================
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxx"
MIDTRANS_IS_PRODUCTION="false"

# Versi publik (boleh dibaca browser) — isi sama dengan client key di atas
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxx"
NEXT_PUBLIC_MIDTRANS_PRODUCTION="false"

# ============================================================
# VERCEL BLOB — penyimpanan foto produk
# (otomatis terisi saat membuat Blob store di Vercel; untuk lokal salin tokennya)
# ============================================================
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ============================================================
# EMAIL (opsional) — konfirmasi pembayaran via Resend (resend.com)
# Kosongkan kalau belum perlu; aplikasi tetap jalan tanpa email.
# ============================================================
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Yuk Belanja <pesanan@domainanda.com>"
